#!/bin/sh

mkdir /dev /proc /sys /run /tmp /var /mnt /squash
# Preferred: devtmpfs (kernel auto-populates /dev)
mount -t devtmpfs devtmpfs /dev


# Mount kernel filesystems
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys

mount -t tmpfs -o size=64m tmpfs /run
mount -t tmpfs -o size=64m tmpfs /tmp
mount -t tmpfs -o size=64m tmpfs /var

mount -t debugfs none /sys/kernel/debug

#detection
if [ "$(/sbin/soc -f)" = "t20" ]; then
        insmod /lib/sinfo_t20.ko
fi
if [ "$(/sbin/soc -f)" = "t31" ]; then
        insmod /lib/sinfo_t31.ko
fi
gpio-diag show >> /tmp/gpio-diag-output
echo 1 > /proc/jz/sinfo/info &


#Waiting devtmpfs mount
timeout=50
while [ ! -b /dev/mmcblk0p1 ] && [ $timeout -gt 0 ]; do
    sleep 0.01
    timeout=$((timeout - 1))
    echo probe mmcblk0p1 $timeout
done


# add pts for telnetd
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts \
    -o mode=620,ptmxmode=0666

#mount sdcard
mount /dev/mmcblk0p1 /mnt

#start telnet
busybox telnetd -l /bin/sh &


##chroot
mount -o loop /mnt/initramfs_files/squash /squash
for i in /dev /proc /sys /run /tmp /var ; do
   mount --rbind $i /squash$i
done
mount /dev/mmcblk0p1 /squash/mnt

##setup ZRAM
echo lz4 > /sys/block/zram0/comp_algorithm
echo 128M > /sys/block/zram0/disksize
mkswap /dev/zram0
swapon /dev/zram0


##custom script
/mnt/initramfs_files/initramfsrun.sh &

##eth
ifup eth0
udhcpc -i eth0 &

##usb_cdc
usb-role -m device
ifconfig usb0 172.16.1.1 netmask 255.255.255.0 up
udhcpd /etc/udhcpd-usb.conf &

##fix atbm6031 load
ln -s /bin/busybox /sbin/mdev
mkdir /lib/firmware
mount /squash/lib/firmware /lib/firmware
mkdir /usr/share/wifi
mount /squash/usr/share/wifi /usr/share/wifi



##ftpd
tcpsvd -vE 0.0.0.0 21 ftpd -w -A  / &






##mount original firmware to /original
mtd_mount() {
    local part_name="$1"
    local mount_point="$2"
    local mtd_line mtd_num block_dev

    # Validate input arguments
    if [ -z "$part_name" ] || [ -z "$mount_point" ]; then
        echo "Usage: mtd_mount <partition_name> <mount_point>"
        return 1
    fi

    # Find the MTD line matching the partition name
    mtd_line=$(grep "\"$part_name\"" /proc/mtd)
    if [ -z "$mtd_line" ]; then
        echo "Error: MTD partition '$part_name' not found."
        return 1
    fi

    # Extract the device number
    mtd_num=$(echo "$mtd_line" | cut -d':' -f1 | sed 's/mtd//')
    block_dev="/dev/mtdblock$mtd_num"

    # Verify block device node exists
    if [ ! -b "$block_dev" ]; then
        echo "Error: Block device $block_dev does not exist."
        return 1
    fi

    # Create mount folder and execute mount operation
    mkdir -p "$mount_point"
    echo "Mounting $block_dev ($part_name) to $mount_point..."
    
    if mount "$block_dev" $mount_point ; then
        echo "Successfully mounted $part_name."
        return 0
    else
        echo "Error: Failed to mount $block_dev."
        return 1
    fi
}

mkdir /original

mtd_mount rootfs /original
if [ $? -eq 1 ]; then 
    mtd_mount rootfs2 /original
    if [ $? -eq 1 ]; then
        echo "Mount original partition failed"
	touch /original_mount_fail
    fi
fi

mtd_mount user /original/usr/
if [ $? -eq 1 ]; then 
    mtd_mount user2 /original/usr/
    if [ $? -eq 1 ]; then
        echo "Mount original partition failed"
	touch /original_mount_fail
    fi
fi

