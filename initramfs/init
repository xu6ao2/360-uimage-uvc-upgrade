mtd_mount_ubi() {
    local part_name="$1"
    local mount_point="$2"

    [ -z "$part_name" ] && return 1
    [ -z "$mount_point" ] && return 1

    local mtd_line
    local mtd_num
    local ubi_num
    local vol_name

    mtd_line=$(grep "\"$part_name\"" /proc/mtd)
    [ -z "$mtd_line" ] && {
        echo "MTD partition $part_name not found"
        return 1
    }

    mtd_num=$(echo "$mtd_line" | cut -d: -f1 | sed 's/mtd//')

    mkdir -p "$mount_point"

    # Attach if not already attached
    busybox ubiattach /dev/ubi_ctrl -m "$mtd_num"

    ubi_vol=$(ls /dev/ubi*_? 2>/dev/null | busybox tail -1)
    ubi_num=$(echo "$ubi_vol" | sed -n 's#/dev/ubi\([0-9]*\)_[0-9]*#\1#p')
    [ -z "$ubi_vol" ] && return 1
    [ -z "$ubi_num" ] && return 1


    dd if="$ubi_vol" of=/tmp/"$part_name"
    busybox ubidetach /dev/ubi_ctrl -d "$ubi_num"

    # Mount by name
    if mount /tmp/"$part_name" "$mount_point"; then
        echo "Mounted UBI successfully"
        return 0
    fi


    return 1
}

