#fi




if [ ! -e /original_mount_fail ]; then
    ln -s /original/lib/ld-uClibc.so.0 /lib/ld-uClibc.so.0
    ln -s /original/lib/libc.so.0  /lib/libc.so.0
    ln -s /original/usr/sbin/mtd_debug /sbin/mtd_debug
    ln -s /original/usr/bin/nvram_get /bin/nvram_get
fi









/bin/sh
